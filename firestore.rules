rules_version = '2';

// ===========================================
// PIXLY - Firestore Security Rules
// Production-Ready Configuration
// ===========================================

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================
    // HELPER FUNCTIONS
    // =========================================

    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the authenticated user matches the userId
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if user is a member of the workspace (for read operations)
    function isWorkspaceMember(workspaceId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/workspaces/$(workspaceId)) &&
        request.auth.uid in get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.memberIds;
    }

    // Check membership from resource data (for queries on collections)
    function isWorkspaceMemberFromData() {
      return isAuthenticated() && request.auth.uid in resource.data.memberIds;
    }

    // Validate email format
    function isValidEmail(email) {
      return email is string && email.matches('^[^@]+@[^@]+\\.[^@]+$');
    }

    // Validate plan type
    function isValidPlan(plan) {
      return plan in ['free', 'starter', 'growth', 'scale', 'unlimited'];
    }

    // Validate attribution model
    function isValidAttributionModel(model) {
      return model in ['last_click', 'first_click', 'linear', 'time_decay', 'position_based'];
    }

    // =========================================
    // USERS COLLECTION
    // Document ID = Firebase Auth UID
    // =========================================
    match /users/{userId} {
      // Users can read their own data
      allow read: if isOwner(userId);

      // Users can create their own profile on signup
      // Document structure from auth.ts:
      // { email, displayName, photoURL, createdAt, updatedAt, plan, workspaceIds }
      allow create: if isOwner(userId) &&
        // Required: valid email
        request.resource.data.keys().hasAll(['email', 'plan', 'workspaceIds']) &&
        isValidEmail(request.resource.data.email) &&
        // Plan must be valid
        isValidPlan(request.resource.data.plan) &&
        // workspaceIds must be an empty array on creation
        request.resource.data.workspaceIds is list &&
        request.resource.data.workspaceIds.size() == 0;

      // Users can update their own profile
      // Allows partial updates (only workspaceIds, displayName, etc.)
      allow update: if isOwner(userId) &&
        // Cannot change email (immutable)
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['email']) ||
         request.resource.data.email == resource.data.email) &&
        // Cannot change createdAt (immutable)
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['createdAt']) ||
         request.resource.data.createdAt == resource.data.createdAt) &&
        // If plan is being changed, it must be valid
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['plan']) ||
         isValidPlan(request.resource.data.plan)) &&
        // If workspaceIds is being changed, it must be a list
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['workspaceIds']) ||
         request.resource.data.workspaceIds is list);

      // Users cannot delete their profile
      allow delete: if false;
    }

    // =========================================
    // WORKSPACES COLLECTION
    // =========================================
    match /workspaces/{workspaceId} {
      // Members can read workspace data
      allow read: if isAuthenticated() &&
        request.auth.uid in resource.data.memberIds;

      // Authenticated users can create workspaces
      // They automatically become owner and first member
      allow create: if isAuthenticated() &&
        // Creator must be the owner
        request.resource.data.ownerId == request.auth.uid &&
        // Creator must be in memberIds
        request.auth.uid in request.resource.data.memberIds &&
        // Required fields
        request.resource.data.keys().hasAll(['name', 'ownerId', 'memberIds', 'pixelId', 'settings', 'integrations']) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.pixelId is string &&
        request.resource.data.pixelId.size() > 0 &&
        // Settings validation
        request.resource.data.settings.keys().hasAll(['timezone', 'currency', 'attributionWindow', 'defaultAttributionModel']) &&
        isValidAttributionModel(request.resource.data.settings.defaultAttributionModel);

      // Owner or members can update workspace
      // Allows partial updates for settings, integrations, memberIds
      allow update: if isAuthenticated() &&
        request.auth.uid in resource.data.memberIds &&
        // Cannot change ownerId (immutable)
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['ownerId']) ||
         request.resource.data.ownerId == resource.data.ownerId) &&
        // Cannot change pixelId (immutable)
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['pixelId']) ||
         request.resource.data.pixelId == resource.data.pixelId) &&
        // Cannot change createdAt (immutable)
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['createdAt']) ||
         request.resource.data.createdAt == resource.data.createdAt) &&
        // If settings is being changed, validate attribution model
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['settings']) ||
         isValidAttributionModel(request.resource.data.settings.defaultAttributionModel));

      // Only owner can delete workspace
      allow delete: if isAuthenticated() &&
        request.auth.uid == resource.data.ownerId;
    }

    // =========================================
    // EVENTS COLLECTION
    // Created by server/Admin SDK via /api/track
    // Client needs read access for analytics dashboard
    // =========================================
    match /events/{eventId} {
      // Workspace members can read events
      // Uses workspaceId field in the event document
      allow read: if isAuthenticated() &&
        isWorkspaceMember(resource.data.workspaceId);

      // Events are created server-side only (Admin SDK)
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // =========================================
    // SESSIONS COLLECTION
    // Created/updated by server/Admin SDK
    // =========================================
    match /sessions/{sessionId} {
      // Workspace members can read sessions
      allow read: if isAuthenticated() &&
        isWorkspaceMember(resource.data.workspaceId);

      // Sessions are managed server-side only
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // =========================================
    // CONVERSIONS COLLECTION
    // Created by server via tracking/webhooks
    // Client needs read access for dashboard
    // =========================================
    match /conversions/{conversionId} {
      // Workspace members can read conversions
      allow read: if isAuthenticated() &&
        isWorkspaceMember(resource.data.workspaceId);

      // Conversions are created server-side only
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // =========================================
    // CATCH-ALL: DENY EVERYTHING ELSE
    // =========================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
