rules_version = '2';

// ===========================================
// PIXLY - Firebase Storage Security Rules
// Lead Backend & Security Configuration
// ===========================================

service firebase.storage {
  match /b/{bucket}/o {

    // =========================================
    // HELPER FUNCTIONS
    // =========================================

    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the user owns this resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Validate file size (max 5MB)
    function isValidFileSize() {
      return request.resource.size < 5 * 1024 * 1024;
    }

    // Validate image content type
    function isImageType() {
      return request.resource.contentType.matches('image/.*');
    }

    // =========================================
    // USER AVATARS
    // Path: /avatars/{userId}/{filename}
    // =========================================
    match /avatars/{userId}/{allPaths=**} {
      // Users can read any avatar (public)
      allow read: if true;

      // Users can only upload their own avatar
      allow create: if isOwner(userId) &&
        isValidFileSize() &&
        isImageType();

      // Users can update their own avatar
      allow update: if isOwner(userId) &&
        isValidFileSize() &&
        isImageType();

      // Users can delete their own avatar
      allow delete: if isOwner(userId);
    }

    // =========================================
    // WORKSPACE LOGOS
    // Path: /workspaces/{workspaceId}/logo/{filename}
    // Note: Access control via Firestore lookup would require
    // Cloud Functions, so we use a simpler approach here
    // =========================================
    match /workspaces/{workspaceId}/logo/{allPaths=**} {
      // Anyone authenticated can read workspace logos
      allow read: if isAuthenticated();

      // Only authenticated users can upload (workspace membership
      // should be validated in application code)
      allow create, update: if isAuthenticated() &&
        isValidFileSize() &&
        isImageType();

      // Only authenticated users can delete
      allow delete: if isAuthenticated();
    }

    // =========================================
    // WORKSPACE FILES (Reports, Exports, etc.)
    // Path: /workspaces/{workspaceId}/files/{filename}
    // =========================================
    match /workspaces/{workspaceId}/files/{allPaths=**} {
      // Only authenticated users can access
      allow read: if isAuthenticated();

      // Allow file uploads with size limit (10MB for reports)
      allow create, update: if isAuthenticated() &&
        request.resource.size < 10 * 1024 * 1024;

      allow delete: if isAuthenticated();
    }

    // =========================================
    // DENY ALL OTHER PATHS
    // =========================================
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
